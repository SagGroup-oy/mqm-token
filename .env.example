# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# Polygon Amoy Testnet RPC
POLYGON_AMOY_RPC=https://rpc-amoy.polygon.technology

# Polygon Mainnet RPC
POLYGON_MAINNET_RPC=https://polygon-rpc.com

# Deployer private key (testnet wallet only — never use mainnet key here)
PRIVATE_KEY=your_testnet_private_key_here

# Polygonscan API key (for contract verification)
POLYGONSCAN_API_KEY=your_polygonscan_api_key_here

# Wallet addresses for token allocation
ICO_WALLET=0x0000000000000000000000000000000000000000
TEAM_WALLET=0x0000000000000000000000000000000000000000
ECOSYSTEM_WALLET=0x0000000000000000000000000000000000000000
LIQUIDITY_WALLET=0x0000000000000000000000000000000000000000
RESERVE_WALLET=0x0000000000000000000000000000000000000000
ADVISOR_WALLET=0x0000000000000000000000000000000000000000
